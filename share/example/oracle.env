# If you wish to set the PATH in addition to teh ORACLE_HOME/bin added by oraenv
PATH=/usr/bin:/usr/local/bin
ORACLE_UNQNAME=orcl
# ORACLE_SID must be set as it is the key to this file
ORACLE_SID=orcl1
ORACLE_HOSTNAME=oel.ipa.home
# Set LD_LIBRARY_PATH if there are other shared libraries are required other then
# those in ORACLE_HOME/lib - otherwise do not set
LD_LIBRARY_PATH=/opt/oracle/product/19c/dbhome/lib; export LD_LIBRARY_PAIH
# It is not necessary to set ORACLE_BASE as oraenv will set it
ORACLE_BASE=
OH=/opt/oracle/product/19c/dbhome; export OH
# It is not necessary to set ORACLE_HOME as oraenv will set it
ORACLE_HOME=
TNS_ADMIN=/etc/opt/oracle/network/admin; export TNS_ADMIN
